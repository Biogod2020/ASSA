{
  "hooks": {
    "BeforeAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "Capture",
            "type": "command",
            "command": "node ${extensionPath}/hooks/capture_payload.js"
          },
          {
            "name": "ASSA BeforeAgent",
            "type": "command",
            "command": "node ${extensionPath}/hooks/beforeAgentHook.js",
            "timeout": 60000
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "ASSA AfterTool",
            "type": "command",
            "command": "node ${extensionPath}/hooks/afterToolHook.js",
            "timeout": 60000
          }
        ]
      }
    ]
  }
}
